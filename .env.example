# --- Required for ALL Labs ---
PROJECT_ENDPOINT= <Enter your project endpoint>
MODEL_DEPLOYMENT_NAME=gpt-4o-mini
 
# --- Required for Lab 7 (Tavily Web Search) ---
TAVILY_API_KEY=tvly-YOUR_TAVILY_API_KEY

# --- Required for Lab 10 (Azure AI Search) ---
AI_SEARCH_CONNECTION_NAME=<your-search-connection-name>
AI_SEARCH_INDEX_NAME=contoso-insurance-index

# --- Required for Production Observability (Lab 8 + Lab 11) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=<your-connection-string>
 